{
  "name": "@vuqs/nuxt",
  "type": "module",
  "version": "0.0.0",
  "description": "Nuxt module for vuqs — auto-imported query-state composables and an out-of-box vue-router adapter.",
  "author": "João Pedro Antunes Silva <hi@joaopedroas.com>",
  "license": "MIT",
  "homepage": "https://JoaoPedroAS51.github.io/vuqs/nuxt/introduction",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoaoPedroAS51/vuqs.git",
    "directory": "packages/nuxt"
  },
  "keywords": [
    "nuxt",
    "vue",
    "query",
    "state",
    "url",
    "router",
    "type-safe",
    "composable"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "module": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "nuxt-module-build prepare && nuxt-module-build build",
    "dev": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "test": "vitest run --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:types": "vitest --typecheck.only --run --passWithNoTests",
    "typecheck": "nuxt-module-build prepare && vue-tsc --noEmit",
    "prepublishOnly": "nuxt-module-build prepare && nuxt-module-build build"
  },
  "dependencies": {
    "@nuxt/kit": "catalog:",
    "defu": "catalog:",
    "vuqs": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "catalog:",
    "@nuxt/schema": "catalog:",
    "@types/node": "catalog:",
    "nuxt": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
