{
  "name": "@vuqs/nuxt",
  "type": "module",
  "version": "0.0.0",
  "description": "Nuxt module for vuqs — auto-imported query-state composables and an out-of-box vue-router adapter.",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "module": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "nuxt-module-build prepare && nuxt-module-build build",
    "dev": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "test": "vitest run --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:types": "vitest --typecheck.only --run --passWithNoTests",
    "typecheck": "nuxt-module-build prepare && vue-tsc --noEmit",
    "prepublishOnly": "nuxt-module-build prepare && nuxt-module-build build"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "defu": "^6.0.0",
    "vuqs": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.0",
    "@nuxt/schema": "^4.0.0",
    "@types/node": "^22.0.0",
    "nuxt": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
