{
  "name": "@vuqs/store",
  "type": "module",
  "version": "0.0.0",
  "description": "Opinionated query-state store for Vue 3 — runtime defaults and context-aware reset, built on vuqs.",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest",
    "test:run": "vitest run",
    "test:types": "vitest --typecheck.only --run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "vuqs": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "unbuild": "^3.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
