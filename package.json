{
  "name": "vuqs-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "description": "Monorepo for vuqs — type-safe query state for Vue 3.",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm --filter './packages/*' build",
    "dev": "pnpm --filter './packages/*' dev",
    "test": "pnpm --filter './packages/*' test",
    "test:run": "pnpm --filter './packages/*' test:run",
    "test:types": "pnpm --filter './packages/*' test:types",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "playground": "pnpm --filter vuqs build && pnpm --filter @vuqs/playground dev",
    "playground:build": "pnpm --filter vuqs build && pnpm --filter @vuqs/playground build",
    "docs:dev": "pnpm --filter vuqs build && pnpm --filter @vuqs/docs dev",
    "docs:build": "pnpm --filter vuqs build && pnpm --filter @vuqs/docs build"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
