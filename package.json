{
  "name": "vuqs-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "description": "Monorepo for vuqs — type-safe query state for Vue 3.",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm --filter vuqs build",
    "dev": "pnpm --filter vuqs dev",
    "test": "pnpm --filter vuqs test",
    "test:run": "pnpm --filter vuqs test:run",
    "test:types": "pnpm --filter vuqs test:types",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
