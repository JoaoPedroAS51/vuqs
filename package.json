{
  "name": "vuqs",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.3",
  "description": "Type-safe query state for Vue 3 — composable codecs, URL sync, and a context-aware store.",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:types": "vitest --typecheck.only --run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "unbuild": "^3.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
